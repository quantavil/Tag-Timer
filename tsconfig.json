{
    "compilerOptions": {
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ES2022",
        "allowJs": true,
        "moduleResolution": "Bundler",
        "importHelpers": true,
        "isolatedModules": true,
        "strict": true,
        "lib": [
            "DOM",
            "ES2022"
        ]
    },
    "include": [
        "**/*.ts"
    ]
